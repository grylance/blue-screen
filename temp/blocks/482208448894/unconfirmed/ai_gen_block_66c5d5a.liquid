{% doc %}
  @prompt
    Add a logo image block to the newsletter section that allows merchants to upload and display their logo image with configurable width/height settings.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-image-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-align: {{ block.settings.alignment }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-logo-image__wrapper-{{ ai_gen_id }} {
    display: inline-block;
    max-width: 100%;
  }

  .ai-logo-image__img-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: auto;
    max-width: 100%;
    display: block;
  }

  .ai-logo-image__placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    max-width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    position: relative;
  }

  .ai-logo-image__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    opacity: 0.3;
  }

  .ai-logo-image__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-logo-image__img-{{ ai_gen_id }},
    .ai-logo-image__placeholder-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-logo-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-image__wrapper-{{ ai_gen_id }}">
    {% if block.settings.logo != blank %}
      <img
        src="{{ block.settings.logo | image_url: width: 800 }}"
        alt="{{ block.settings.logo.alt | default: shop.name | escape }}"
        class="ai-logo-image__img-{{ ai_gen_id }}"
        width="{{ block.settings.logo.width }}"
        height="{{ block.settings.logo.height }}"
        loading="lazy"
      >
    {% else %}
      <div class="ai-logo-image__placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-logo-image__empty-state-{{ ai_gen_id }}">
          Add your logo
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Logo image",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Desktop width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Mobile width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Logo image"
    }
  ]
}
{% endschema %}

{% doc %}
  @prompt
    overlay logo on video
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-logo-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-video-logo-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-video-logo-video-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-video-logo-overlay-{{ ai_gen_id }} {
    position: absolute;
    z-index: 2;
    pointer-events: none;
  }

  .ai-video-logo-overlay-{{ ai_gen_id }}--top-left {
    top: {{ block.settings.logo_offset }}px;
    left: {{ block.settings.logo_offset }}px;
  }

  .ai-video-logo-overlay-{{ ai_gen_id }}--top-center {
    top: {{ block.settings.logo_offset }}px;
    left: 50%;
    transform: translateX(-50%);
  }

  .ai-video-logo-overlay-{{ ai_gen_id }}--top-right {
    top: {{ block.settings.logo_offset }}px;
    right: {{ block.settings.logo_offset }}px;
  }

  .ai-video-logo-overlay-{{ ai_gen_id }}--center-left {
    top: 50%;
    left: {{ block.settings.logo_offset }}px;
    transform: translateY(-50%);
  }

  .ai-video-logo-overlay-{{ ai_gen_id }}--center-center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .ai-video-logo-overlay-{{ ai_gen_id }}--center-right {
    top: 50%;
    right: {{ block.settings.logo_offset }}px;
    transform: translateY(-50%);
  }

  .ai-video-logo-overlay-{{ ai_gen_id }}--bottom-left {
    bottom: {{ block.settings.logo_offset }}px;
    left: {{ block.settings.logo_offset }}px;
  }

  .ai-video-logo-overlay-{{ ai_gen_id }}--bottom-center {
    bottom: {{ block.settings.logo_offset }}px;
    left: 50%;
    transform: translateX(-50%);
  }

  .ai-video-logo-overlay-{{ ai_gen_id }}--bottom-right {
    bottom: {{ block.settings.logo_offset }}px;
    right: {{ block.settings.logo_offset }}px;
  }

  .ai-video-logo-image-{{ ai_gen_id }} {
    max-width: {{ block.settings.logo_width }}px;
    height: auto;
    display: block;
    opacity: {{ block.settings.logo_opacity }};
  }

  .ai-video-logo-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-logo-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-video-logo-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-video-logo-image-{{ ai_gen_id }} {
      max-width: {{ block.settings.logo_width | times: 0.7 }}px;
    }

    .ai-video-logo-overlay-{{ ai_gen_id }}--top-left,
    .ai-video-logo-overlay-{{ ai_gen_id }}--center-left,
    .ai-video-logo-overlay-{{ ai_gen_id }}--bottom-left {
      left: {{ block.settings.logo_offset | times: 0.5 }}px;
    }

    .ai-video-logo-overlay-{{ ai_gen_id }}--top-right,
    .ai-video-logo-overlay-{{ ai_gen_id }}--center-right,
    .ai-video-logo-overlay-{{ ai_gen_id }}--bottom-right {
      right: {{ block.settings.logo_offset | times: 0.5 }}px;
    }

    .ai-video-logo-overlay-{{ ai_gen_id }}--top-left,
    .ai-video-logo-overlay-{{ ai_gen_id }}--top-center,
    .ai-video-logo-overlay-{{ ai_gen_id }}--top-right {
      top: {{ block.settings.logo_offset | times: 0.5 }}px;
    }

    .ai-video-logo-overlay-{{ ai_gen_id }}--bottom-left,
    .ai-video-logo-overlay-{{ ai_gen_id }}--bottom-center,
    .ai-video-logo-overlay-{{ ai_gen_id }}--bottom-right {
      bottom: {{ block.settings.logo_offset | times: 0.5 }}px;
    }
  }
{% endstyle %}

<div class="ai-video-logo-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-logo-wrapper-{{ ai_gen_id }}">
    {% if block.settings.video != blank %}
      <video
        class="ai-video-logo-video-{{ ai_gen_id }}"
        {% if block.settings.autoplay %}autoplay{% endif %}
        {% if block.settings.loop %}loop{% endif %}
        {% if block.settings.muted %}muted{% endif %}
        {% if block.settings.controls %}controls{% endif %}
        playsinline
      >
        <source src="{{ block.settings.video }}" type="video/mp4">
      </video>
    {% else %}
      <div class="ai-video-logo-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-video-logo-empty-state-{{ ai_gen_id }}">
          Next, add a video
        </div>
      </div>
    {% endif %}

    {% if block.settings.logo != blank %}
      <div class="ai-video-logo-overlay-{{ ai_gen_id }} ai-video-logo-overlay-{{ ai_gen_id }}--{{ block.settings.logo_position }}">
        <img
          src="{{ block.settings.logo | image_url: width: 600 }}"
          alt="{{ block.settings.logo.alt | escape }}"
          class="ai-video-logo-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.logo.width }}"
          height="{{ block.settings.logo.height }}"
        >
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Video with logo overlay",
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Muted",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "controls",
      "label": "Show controls",
      "default": false
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Logo overlay"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "select",
      "id": "logo_position",
      "label": "Position",
      "options": [
        {
          "value": "top-left",
          "label": "Top left"
        },
        {
          "value": "top-center",
          "label": "Top center"
        },
        {
          "value": "top-right",
          "label": "Top right"
        },
        {
          "value": "center-left",
          "label": "Center left"
        },
        {
          "value": "center-center",
          "label": "Center"
        },
        {
          "value": "center-right",
          "label": "Center right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom left"
        },
        {
          "value": "bottom-center",
          "label": "Bottom center"
        },
        {
          "value": "bottom-right",
          "label": "Bottom right"
        }
      ],
      "default": "top-left"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_offset",
      "label": "Offset from edge",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "label": "Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 1
    }
  ],
  "presets": [
    {
      "name": "Video with logo overlay"
    }
  ]
}
{% endschema %}
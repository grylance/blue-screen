{{ 'video-section.css' | asset_url | stylesheet_tag }}

{%- style -%}
.video-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  z-index: 1;
}

.video-wrapper iframe,
.video-wrapper video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.video-wrapper video {
  pointer-events: none;
}

/* SOUND TOGGLE */

.sound-toggle {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 10;
  background: none;
  border: none;
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.3s ease;
}

/* only show on hover */
body:hover .sound-toggle {
  opacity: 0.6;
}

.sound-toggle:hover {
  opacity: 1;
}
{%- endstyle -%}

<div class="video-wrapper">

  {%- if section.settings.video == null and section.settings.video_url != null -%}

    <iframe
      id="bg-video"
      src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1&loop=1&muted=1&background=1&api=1"
      frameborder="0"
      allow="autoplay; fullscreen"
      allowfullscreen>
    </iframe>

  {%- else -%}

    {{
      section.settings.video
      | video_tag:
        autoplay: true,
        loop: true,
        muted: true,
        controls: false,
        playsinline: true,
        id: 'bg-video'
    }}

  {%- endif -%}

</div>

<button class="sound-toggle" id="soundToggle" aria-label="Toggle sound">

  <!-- SOUND ON -->
  <span id="icon-on" style="display:none;">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
      <path d="M3 10v4h4l5 5V5l-5 5H3z"/>
      <path d="M16.5 12c0-1.77-1-3.29-2.5-4.03v8.05c1.5-.74 2.5-2.26 2.5-4.02z"/>
      <path d="M14 3.23v2.06c2.89 1 5 3.77 5 6.71s-2.11 5.71-5 6.71v2.06c4.01-1.1 7-4.73 7-8.77s-2.99-7.67-7-8.77z"/>
    </svg>
  </span>

  <!-- SOUND OFF -->
  <span id="icon-off">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
      <path d="M3 10v4h4l5 5V5l-5 5H3z"/>
      <line x1="16" y1="8" x2="22" y2="16" stroke="white" stroke-width="2"/>
      <line x1="22" y1="8" x2="16" y2="16" stroke="white" stroke-width="2"/>
    </svg>
  </span>

</button>

<script src="https://player.vimeo.com/api/player.js"></script>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const btn = document.getElementById("soundToggle");
  const video = document.getElementById("bg-video");

  const iconOn = document.getElementById("icon-on");
  const iconOff = document.getElementById("icon-off");

  let isMuted = true;

  function updateIcon() {
    iconOn.style.display = isMuted ? "none" : "inline";
    iconOff.style.display = isMuted ? "inline" : "none";
  }

  updateIcon();

  // Vimeo
  if (video && video.tagName === "IFRAME") {
    const player = new Vimeo.Player(video);

    btn.addEventListener("click", async () => {
      isMuted = !isMuted;
      await player.setVolume(isMuted ? 0 : 1);
      updateIcon();
    });
  }

  // Native video
  if (video && video.tagName === "VIDEO") {
    video.muted = true;

    btn.addEventListener("click", () => {
      isMuted = !isMuted;
      video.muted = isMuted;
      updateIcon();
    });
  }

});
</script>

{% schema %}
{
  "name": "Fullscreen Video",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Upload video"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["vimeo"],
      "label": "Vimeo URL"
    }
  ],
  "presets": [
    {
      "name": "Fullscreen Video"
    }
  ]
}
{% endschema %}
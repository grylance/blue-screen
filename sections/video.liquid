{{ 'video-section.css' | asset_url | stylesheet_tag }}

{%- style -%}
.video-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  z-index: 1;
}

.video-wrapper iframe,
.video-wrapper video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.video-wrapper video {
  pointer-events: none;
}

.sound-toggle {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 10;
  background: none;
  border: none;
  color: white;
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  opacity: 0.8;
}

.sound-toggle:hover {
  opacity: 1;
}
{%- endstyle -%}

<div class="video-wrapper">

  {%- if section.settings.video == null and section.settings.video_url != null -%}

    {%- if section.settings.video_url.type == 'vimeo' -%}

      <iframe
        id="bg-video"
        src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1&loop=1&muted=1&background=1&api=1"
        frameborder="0"
        allow="autoplay; fullscreen"
        allowfullscreen>
      </iframe>

    {%- endif -%}

  {%- else -%}

    {{
      section.settings.video
      | video_tag:
        autoplay: true,
        loop: true,
        muted: true,
        controls: false,
        playsinline: true,
        id: 'bg-video'
    }}

  {%- endif -%}

</div>

<button class="sound-toggle" id="soundToggle">Sound on</button>

<script src="https://player.vimeo.com/api/player.js"></script>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const btn = document.getElementById("soundToggle");
  const video = document.getElementById("bg-video");

  let isMuted = true;

  function updateLabel() {
    btn.textContent = isMuted ? "Sound on" : "Sound off";
  }

  updateLabel();

  // Vimeo
  if (video && video.tagName === "IFRAME") {
    const player = new Vimeo.Player(video);

    btn.addEventListener("click", async () => {
      isMuted = !isMuted;
      await player.setVolume(isMuted ? 0 : 1);
      updateLabel();
    });
  }

  // Native video
  if (video && video.tagName === "VIDEO") {
    video.muted = true;

    btn.addEventListener("click", () => {
      isMuted = !isMuted;
      video.muted = isMuted;
      updateLabel();
    });
  }

});
</script>

{% schema %}
{
  "name": "Fullscreen Video",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Upload video"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["vimeo"],
      "label": "Vimeo URL"
    }
  ],
  "presets": [
    {
      "name": "Fullscreen Video"
    }
  ]
}
{% endschema %}